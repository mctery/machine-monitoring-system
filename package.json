{
  "name": "machine-monitoring-system",
  "version": "2.3.0",
  "description": "Real-time machine monitoring system for TMOT Manufacturing (Bridgestone Group) - Dashboard with timeline visualization, machine status tracking, and performance analytics",
  "author": "TMOT Manufacturing Operations",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:vercel": "vercel dev",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "node server.cjs",
    "start:pm2": "pm2 start ecosystem.config.cjs",
    "stop:pm2": "pm2 stop machine-monitoring",
    "restart:pm2": "pm2 restart machine-monitoring",
    "logs:pm2": "pm2 logs machine-monitoring",
    "db:setup": "node scripts/db-setup.cjs",
    "db:seed": "node scripts/db-seed.cjs"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "date-fns": "^3.6.0",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "framer-motion": "^12.23.26",
    "lucide-react": "^0.428.0",
    "mysql2": "^3.15.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vercel/node": "^5.5.15",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "tsx": "^4.21.0",
    "typescript": "^5.5.3",
    "vite": "^5.4.0"
  }
}
